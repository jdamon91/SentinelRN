{
  "name": "sentinelrn",
  "version": "0.0.0",
  "private": true,
  "description": "Runtime integrity and AI security for React Native apps.",
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "react-native": "0.76.5",
      "@react-native/community-cli-plugin": "0.76.5"
    }
  },
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "turbo typecheck",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo build --filter=\"./packages/*\" && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@changesets/cli": "^2.31.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.43",
    "@types/react": "18.3.12",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tsup": "^8.5.1",
    "turbo": "^2.10.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
