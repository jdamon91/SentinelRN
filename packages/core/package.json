{
  "name": "@sentinelrn/core",
  "version": "0.1.0",
  "description": "Application Trust Runtime for React Native — runtime integrity and AI security engine.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "keywords": [
    "react-native",
    "security",
    "jailbreak-detection",
    "root-detection",
    "ai-security",
    "prompt-injection",
    "pii",
    "redaction"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jdamon91/SentinelRN.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/jdamon91/SentinelRN/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/jdamon91/SentinelRN/issues"
  }
}
