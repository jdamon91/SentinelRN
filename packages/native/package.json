{
  "name": "@sentinelrn/native",
  "version": "0.1.0",
  "description": "Native runtime-integrity detectors (Android + iOS) for SentinelRN.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "react-native": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "android",
    "ios",
    "SentinelRNNative.podspec",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@sentinelrn/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.73.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-native": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "codegenConfig": {
    "name": "SentinelRNNativeSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.sentinelrn.nativemodule"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jdamon91/SentinelRN.git",
    "directory": "packages/native"
  },
  "homepage": "https://github.com/jdamon91/SentinelRN/tree/main/packages/native#readme",
  "bugs": {
    "url": "https://github.com/jdamon91/SentinelRN/issues"
  }
}
