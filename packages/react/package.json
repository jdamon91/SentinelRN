{
  "name": "@sentinelrn/react",
  "version": "0.1.0",
  "description": "React hooks and provider for SentinelRN.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@sentinelrn/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jdamon91/SentinelRN.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/jdamon91/SentinelRN/tree/main/packages/react#readme",
  "bugs": {
    "url": "https://github.com/jdamon91/SentinelRN/issues"
  }
}
